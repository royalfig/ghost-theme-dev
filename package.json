{
  "name": "@royalfig/gtb",
  "version": "3.3.2",
  "description": "A modern tool for developing and building Ghost themes with esbuild, Tailwind, and Live Reload",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "start": "node dist/index.js",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "bin": {
    "gtb": "dist/index.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ghost",
    "theme",
    "development",
    "build",
    "esbuild",
    "tailwind",
    "livereload"
  ],
  "author": "Ryan Feigenbaum",
  "license": "MIT",
  "dependencies": {
    "@inquirer/confirm": "6.0.8",
    "@inquirer/input": "5.0.8",
    "@inquirer/select": "5.1.0",
    "@tryghost/admin-api": "^1.14.6",
    "archiver": "7.0.1",
    "browserslist": "^4.28.2",
    "chalk": "5.6.2",
    "chokidar": "5.0.0",
    "esbuild": "0.27.3",
    "gscan": "5.3.1",
    "lightningcss": "^1.32.0",
    "open": "^11.0.0",
    "portfinder": "1.0.38",
    "sharp": "0.34.5",
    "ws": "8.19.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/browserslist": "^4.8.0",
    "@types/chokidar": "^1.7.5",
    "@types/node": "25.3.5",
    "@types/ws": "^8.18.1",
    "@vitest/ui": "^2.0.0",
    "jsdom": "^29.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.2",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/royalfig/ghost-theme-dev"
  },
  "publishConfig": {
    "access": "public"
  }
}
